# Discord bot token from the Developer Portal.
DISCORD_TOKEN=your_bot_token_here

# Recommended during development so slash-command updates appear immediately.
DISCORD_GUILD_ID=your_test_server_id_here

# Optional path to the shared provider API-key YAML file. Its github and shodan
# entries also enable the github-subs and shosubgo adapters. For example:
# SUBFINDER_PROVIDER_CONFIG=secrets/provider-config.yaml
# Keep this file outside version control; secrets/ is ignored by this project.
SUBFINDER_PROVIDER_CONFIG=

# Directory where /scan stores timestamped run folders.
RESULTS_DIR=results
