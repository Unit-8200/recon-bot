# Discord bot token from the Developer Portal.
DISCORD_TOKEN=your_bot_token_here

# Recommended during development so slash-command updates appear immediately.
DISCORD_GUILD_ID=your_test_server_id_here

# Optional path to the shared provider API-key YAML file. Its github and shodan
# entries also enable the github-subs and shosubgo adapters. For example:
# SUBFINDER_PROVIDER_CONFIG=secrets/provider-config.yaml
# Keep this file outside version control; secrets/ is ignored by this project.
SUBFINDER_PROVIDER_CONFIG=

# Directory where /subs and /ips store timestamped run folders.
RESULTS_DIR=results

# Optional active DNS discovery. Run scripts/setup-puredns.sh once before
# enabling it. When passive discovery returns at most the configured number of
# names, PureDNS brute-forces the root with the cached n0kovo huge wordlist.
PUREDNS_ENABLED=false
PUREDNS_IMAGE=discord-puredns:2.1.1
PUREDNS_WORDLIST=data/puredns/n0kovo_subdomains_huge.txt
PUREDNS_RESOLVERS=data/puredns/resolvers.txt
PUREDNS_PASSIVE_THRESHOLD=1000
PUREDNS_RATE_LIMIT=5000
PUREDNS_TIMEOUT=2h

# Docker-backed certificate discovery for the /ips command. The default image
# is the same image built by scripts/setup-puredns.sh.
CADUCEUS_IMAGE=discord-puredns:2.1.1
CADUCEUS_TIMEOUT=4h
